# ────────────────────────────────────────────────────────────────────────────────
# SupplyWatch AI — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────────

# ── Node / Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supplywatch
DB_USER=sw_user
DB_PASSWORD=sw_pass
DATABASE_URL=postgresql://sw_user:sw_pass@localhost:5432/supplywatch

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ── ML Service ─────────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Mapbox (for shipment map visualization) ────────────────────────────────────
# Obtain at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Prediction Scheduler ───────────────────────────────────────────────────────
# How often to re-run ML predictions (ms). Default: 15 minutes
PREDICTION_INTERVAL_MS=900000
# Minutes of delay before flagging a shipment as "delayed"
DELAY_THRESHOLD_MINS=120
